# Shared version configuration - single source of truth
# Loaded by Taskfile.yml via dotenv, inherited by all included taskfiles
# Tools are patch-pinned; base images are minor-pinned for automatic patch updates

# Go toolchain and build tools
GO_VERSION=1.25.7
SWAGGER_VERSION=v0.33.1
GOLANGCILINT_VERSION=v2.8.0

# Dev tools
AIR_VERSION=v1.61.5
DELVE_VERSION=v1.25.1
BUN_VERSION=1.2.13
SPECTRAL_VERSION=6.14.2
HELM_VERSION=v4.0.4
HELM_UNITTEST_VERSION=v1.0.3
HELM_DOCS_VERSION=1.14.2
AH_VERSION=1.22.0
ORAS_VERSION=1.3.2
AJV_CLI_VERSION=5.0.0
NODE_IMAGE_VERSION=22

# Base images (minor-pinned)
ALPINE_VERSION=3.23
NGINX_VERSION=1.28
VALKEY_VERSION=8
POSTGRES_VERSION=16

# External dependencies
DISTRIBUTION_VERSION=v3.0.0
TRIVY_VERSION=0.69.3
TRIVY_BASE_IMAGE_VERSION=0.69.3
HARBOR_SCANNER_TRIVY_VERSION=v0.35.2
LPROBE_VERSION=0.1.7
