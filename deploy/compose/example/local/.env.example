COMPOSE_PROJECT_NAME=harbor-local

# Leave empty for local images, or set to pull from a remote registry:
# IMAGE_REPO=8gears.container-registry.com/8gcr/
IMAGE_REPO=
HARBOR_TAG=v2.15.0
EXT_ENDPOINT=http://localhost
HARBOR_ADMIN_PASSWORD=Harbor12345
CORE_SECRET=not-a-secret-only-for-local-development
JOBSERVICE_SECRET=not-a-secret-only-for-local-development
DB_PASSWORD=harbor-local-dev
LOG_LEVEL=info

# Disable TLS for local development (mounts empty files)
TLS_CONF=/dev/null
TLS_CERT=/dev/null
TLS_KEY=/dev/null
