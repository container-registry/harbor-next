COMPOSE_PROJECT_NAME=harbor

# Image registry prefix — leave empty for locally built images
IMAGE_REPO=8gears.container-registry.com/8gcr/

# Required — Harbor image tag
HARBOR_TAG=v2.15.0

# Required — public URL for Docker client token auth
EXT_ENDPOINT=https://registry.example.com

# Required — secrets (generate with: openssl rand -hex 32)
HARBOR_ADMIN_PASSWORD=
CORE_SECRET=
JOBSERVICE_SECRET=
DB_PASSWORD=

# Optional overrides
# DB_USER=postgres
# DB_NAME=registry
# DB_SSLMODE=disable
# LOG_LEVEL=info
# PORT_HTTP=80
# PORT_HTTPS=443
# CACHE_ENABLED=true
# WITH_TRIVY=true

## External Redis (defaults to the bundled Valkey container)
# REDIS_HOST=redis
# REDIS_PORT=6379

## Required — TLS certificate and private key (absolute paths on host)
TLS_CERT=/etc/letsencrypt/live/registry.example.com/fullchain.pem
TLS_KEY=/etc/letsencrypt/live/registry.example.com/privkey.pem
# TLS_CONF=./config/nginx/tls.conf

## Registry basic-auth credentials (leave empty unless your registry requires them)
# REGISTRY_CREDENTIAL_USERNAME=
# REGISTRY_CREDENTIAL_PASSWORD=
