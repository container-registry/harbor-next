# Required — Harbor image tag
HARBOR_TAG=v2.15.0

# Required — public URL for Docker client token auth
EXT_ENDPOINT=https://registry.example.com

# Required — secrets (generate with: openssl rand -hex 32)
HARBOR_ADMIN_PASSWORD=
CORE_SECRET=
JOBSERVICE_SECRET=
DB_PASSWORD=

# Optional overrides
# DB_USER=postgres
# DB_NAME=registry
# DB_SSLMODE=disable
# LOG_LEVEL=info
# PORT_HTTP=80
# PORT_HTTPS=443
# CACHE_ENABLED=true
# WITH_TRIVY=true
