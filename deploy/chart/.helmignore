# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/
# Claude Code
.claude/
# Documentation sources
README.md.gotmpl
# Artifact Hub repo metadata — pushed as a separate OCI artifact, not chart content
artifacthub-repo.yml
# CI/CD
.github/
.gitlab-ci.yml
# Testing
tests/
# YAMLScript tooling (migrator, schema drift, values lint, rendered-config checks)
tools/
.schema-drift-allow
# Development
Taskfile.yaml
Taskfile.yml
.pre-commit-config.yaml
# Task cache
.task/
