        app.kubernetes.io/instance: harbor
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: harbor-next
        app.kubernetes.io/version: v2.15.0
        helm.sh/chart: harbor-next-3.0.0
      name: harbor-harbor-next-core
    spec:
      ports:
